{
  "name": "tengen",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm -w @tengen/web run dev --",
    "build": "npm run build --workspaces --if-present",
    "build:web": "npm run build -w @tengen/web",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "npm run lint --workspaces --if-present",
    "preview": "npm -w @tengen/web run preview --",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "prettier": "^3.8.3"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
