{
  "name": "@tengen/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Authoritative game server for Tengen sessions, backed by @tengen/game-core.",
  "scripts": {
    "dev": "node --experimental-transform-types --no-warnings --watch src/index.ts",
    "start": "node --experimental-transform-types --no-warnings src/index.ts",
    "smoke": "node --experimental-transform-types --no-warnings src/smoke.ts",
    "test": "node --test --experimental-transform-types --no-warnings test/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tengen/game-core": "*"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
